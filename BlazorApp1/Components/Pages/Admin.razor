@page "/Admin"
@layout EmptyLayout
@using Microsoft.AspNetCore.Authorization
@using BlazorApp1.Components.Admin
@attribute [Authorize(Roles = "Admin")]
<nav class="navbar navbar-expand-lg navbar-dark navbar-colegio">
    <div class="container-fluid">

        <a class="navbar-brand d-flex align-items-center">
            <img src="imagenes/logoColegio.png"
                 style="height:40px; margin-right:10px;">
            Colegio Nuevo Horizonte
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="nav">

            <ul class="navbar-nav me-auto">

                <li class="nav-item">
                    <a class="nav-link active"
                       @onclick='()=>vistaActual = "Usuarios"'>Ver Usuarios</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="">Ver Maestros</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="">Ver Estudiantes</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="">Ver Cursos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="">Ver Grados</a>
                </li>

            </ul>

            <!-- RIGHT SIDE -->
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/logout">
                        <i class="bi bi-box-arrow-in-right"></i> Cerrar Sesión
                    </a>
                </li>

            </ul>

        </div>
    </div>
</nav>
@if (vistaActual == "Usuarios")
{
    <Usuario />
}
@code {
    string vistaActual = "Usuarios";

}
