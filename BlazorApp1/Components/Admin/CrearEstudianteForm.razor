@using BlazorApp1.Models
@using BlazorApp1.Repositorio
@inject IEstudianteRepositorio repo
@inject IGradoRepositorio repoGrado
@inject DialogService dialogService
<RadzenTemplateForm TItem="Estudiante"
    Data="@estudiante"
    Submit="@Guardar">
    <RadzenValidationSummary />

    <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">

        <RadzenLabel Text="Usuario Estudiante" />

        <RadzenDropDown Name="IdEstudiante"
                        Data="@usuarios"
                        @bind-Value="estudiante.IdUsuario"
                        TextProperty="Nombre"
                        ValueProperty="IdUsuario"
                        Style="width:100%" />
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">

        <RadzenLabel Text="Grado" />

        <RadzenDropDown Name="IdGrado"
                        Data="@grados"
                        @bind-Value="estudiante.IdGrado"
                        TextProperty="Nombre"
                        ValueProperty="IdGrado"
                        Style="width:100%" />
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Vertical"
                 AlignItems="AlignItems.Center"
                 Gap="0.5rem">
        <RadzenLabel Text="" Component="espacio" />
        <RadzenButton ButtonType="ButtonType.Submit"
                      Text="Guardar"
                      Icon="save"
                      ButtonStyle="ButtonStyle.Success" />

    </RadzenStack>
   
     

</RadzenTemplateForm>
@code {
    [Parameter]
    public Estudiante estudiante { get; set; } = new();

    private List<Usuario> usuarios = new();

    private List<Grado> grados = new();

    protected override async Task OnInitializedAsync()
    {
        usuarios = await repo.GetUsuarioDisponibleEstudiante();
        grados = await repoGrado.GetGrados();
    }

    async Task Guardar()
    {
        await repo.CrearEstudiante(estudiante);

        dialogService.Close(true);
    }
}
