@page "/"
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using BlazorApp1.Components.MiddleWare
@using Microsoft.AspNetCore.Authentication.Cookies;
@using BlazorApp1.Repositorio
@inject DialogService dialogService
@inject NavigationManager nav
@inject ApplicationDbContext db
@inject IUsuarioRepositorio repo
@layout EmptyLayout
<section class="vh-100 overflow-auto" style="background-color:#f4f6f9;">
    <div class="container  h-100">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-xl-10">
                <div class="card rounded-3 text-black">
                    <div class="row g-0">
                        <div class="col-lg-6">
                            <div class="card-body p-md-5 mx-md-4">

                                <div class="text-center">
                                    <img src="Imagenes/logoColegio.png"
                                         style="width: 185px;" alt="logo">
                                    <h4 class="mt-1 mb-5 pb-1">Somos Colegio Nuevo Horizonte</h4>
                                </div>

                                <EditForm Model ="Input"
                                          OnValidSubmit="OnLogin" FormName="Login">
                                          <DataAnnotationsValidator/>
                                    <p>Porfavor Inicia Sesión con tu Cuenta</p>
                                    <div class="form-floating mb-3">
                                        <input type="email" class="form-control" @bind="Input.Email" />
                                        <label class="form-label" for="form2Example22">Correo Electrónico</label>
                                        <ValidationMessage For="() => Input.Email" class="text-danger" />
                                    </div>
                                    
                                    <div class="form-floating mb-3">
                                        <input type="password" @bind-value="Input.Password" id="form2Example22" class="form-control" />
                                        <label class="form-label" for="form2Example22">Contraseña</label>
                                        <ValidationMessage For="() => Input.Password" class="text-danger" />

                                    </div>

                                    <div class="text-center pt-1 mb-5 pb-1">
                                        <button data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-block fa-lg gradient-custom-2 mb-3" type="submit">
                                            Iniciar Sesión
                                        </button>
                                        @if (!string.IsNullOrEmpty(mensajeError))
                                        {
                                            <div class="alert alert-danger mt-3">
                                                @mensajeError
                                            </div>
                                        }
                                        <RadzenButton Text="¿Olvidó su contraseña?"
                                                      Variant="Variant.Text"
                                                      ButtonStyle="ButtonStyle.Secondary"
                                                      Click="OlvideContrasena"
                                                      Style="padding:0; min-width:0;" />
                                    </div>
                                   

                                </EditForm>

                            </div>
                        </div>
                        <div class="col-lg-6 d-flex align-items-center gradient-custom-2">
                            <div class="text-white px-3 py-4 p-md-5 mx-md-4">
                                <h4 class="mb-4">Somos más que un colegio</h4>
                                <p class="small mb-0">
                                    Colegio Nuevo Horizonte es una institución educativa dedicada a la formación integral de niños y niñas en los niveles de Preprimaria y Primaria. Nuestro compromiso es brindar una educación de calidad en un ambiente seguro, inclusivo y lleno de valores, donde cada estudiante pueda desarrollar sus habilidades académicas, sociales y emocionales.
                                </p>
                                <p>

                                </p>
                                <p class="small mb-0">
                                    A través de metodologías innovadoras y un enfoque centrado en el aprendizaje activo, fomentamos la creatividad, el pensamiento crítico, la responsabilidad y el amor por el conocimiento. Nuestro equipo docente acompaña a cada estudiante en su crecimiento, fortaleciendo su confianza y preparándolo para afrontar con éxito los desafíos del futuro.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();
    private string? mensajeError;
    public async Task OnLogin()
    {
        var usuario = repo.ObtenerPorCorreo(Input.Email);
        if (usuario == null)
        {
            mensajeError = "Correo no encontrado";
            return;
        }
        bool ok = BCrypt.Net.BCrypt.Verify(Input.Password, usuario.Contraseña);

        if (!ok)
        {
            mensajeError = "Contraseña incorrecta";
            return;
        }
        var claims = new List<Claim>
        {
            new Claim(ClaimTypes.NameIdentifier, usuario.IdUsuario.ToString()),
            new Claim(ClaimTypes.Name, usuario.Correo),
            new Claim(ClaimTypes.Role, usuario.Rol),
        };

        var claimIdentity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);

        ClaimsPrincipal claimsPrincipal = new ClaimsPrincipal(claimIdentity);
        Guid key = Guid.NewGuid();
        AuthMiddleware.Logins[key] = claimsPrincipal;

        nav.NavigateTo($"/?key={key}", true);
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";
    }

    async Task OlvideContrasena()
    {
        await dialogService.Alert(
        @<div>
            <p>
                Por favor comuníquese con el administrador del sistema para restablecer su contraseña.
            </p>

            <p>
                <strong>Correo:</strong> admin@gmail.com
            </p>

            <p>
                O bien acuda a la administración del colegio.
            </p>
        </div>,
        "Recuperación de contraseña");
    }
}
