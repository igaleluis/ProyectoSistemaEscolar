@using BlazorApp1.Models
@using BlazorApp1.Repositorio
@inject IGradoRepositorio repo
@inject DialogService dialogService

<RadzenTemplateForm TItem="Grado" Data="@grado" Submit="@Guardar">
    <RadzenValidationSummary />
    <!-- Nombre -->
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
        <RadzenLabel Text="Nombre del Grado" Component="GradoInput" />
        <RadzenTextBox Name="GradoInput"
                       @bind-Value="grado.Nombre"
                       Style="width:100%" />

        <RadzenRequiredValidator Component="GradoInput"
                                 Text="El nombre es obligatorio"
                                 Popup="true" />
    </RadzenStack>

    <!-- Nivel -->
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
        <RadzenLabel Text="Nivel" Component="Nivel" />
        <RadzenDropDown Name="Nivel"
                        @bind-Value="grado.Nivel"
                        Data="@grados"
                        Style="width:100%" />

        <RadzenRequiredValidator Component="Nivel"
                                 Text="Seleccione un nivel"
                                 Popup="true" />
    </RadzenStack>


    <!--Botón-->
    <RadzenStack Orientation="Orientation.Vertical"
                 AlignItems="AlignItems.Center"
                 Gap="0.5rem">
        <RadzenLabel Text="" Component="espacio" />
        <RadzenButton ButtonType="ButtonType.Submit"
                      Text="Guardar"
                      Icon="save"
                      ButtonStyle="ButtonStyle.Success" />

    </RadzenStack>
</RadzenTemplateForm>
@code {
    [Parameter]
    public Grado grado { get; set; } = new();
    private List<string> grados = new()
    {
        "Pre-Primaria",
        "Primaria",
    };
    async Task Guardar()
    {
        if(grado.IdGrado == 0)
        {
            await repo.CrearGrado(grado);
        }
        else
        {
            await repo.ActualizarGrado(grado.IdGrado, grado);
        }
        dialogService.Close(true);
    }

}
