@page "/Admin"
@layout EmptyLayout
@using Microsoft.AspNetCore.Authorization
@using BlazorApp1.Components.Admin
@attribute [Authorize(Roles = "Admin")]

<nav class="navbar navbar-expand-lg navbar-dark navbar-colegio">
    <div class="container-fluid">

        <a class="navbar-brand d-flex align-items-center">
            <img src="imagenes/logoColegio.png"
                 style="height:40px; margin-right:10px;">
            Colegio Nuevo Horizonte
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="nav">

            <ul class="navbar-nav me-auto">

                <li class="nav-item">
                    <a class="nav-link active"
                       @onclick='() => vistaActual = "Usuarios"'>Ver Usuarios</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active"
                       @onclick='() => vistaActual = "Maestros"'>Ver Maestros</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" 
                        @onclick='()=> vistaActual = "Estudiantes"'>Ver Estudiantes</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" 
                    @onclick='()=> vistaActual = "Cursos"'>Ver Cursos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" 
                    @onclick='()=> vistaActual="Grados"'>Ver Grados</a>
                </li>

            </ul>

            
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/logout">
                        <i class="bi bi-box-arrow-in-right"></i> Cerrar Sesión
                    </a>
                </li>

            </ul>

        </div>
    </div>
</nav>


@if (vistaActual == "Usuarios")
{
    <UsuarioGrid />
}else if (vistaActual == "Maestros")
{
    <MaestroGrid />
}else if (vistaActual == "Estudiantes")
{
    <EstudianteGrid/>
}else if (vistaActual == "Cursos")
{
    <CursosGrid/>
}else if (vistaActual == "Grados")
{
    <GradosGrid/>
}

@code {
    string vistaActual = "Usuarios";

}
